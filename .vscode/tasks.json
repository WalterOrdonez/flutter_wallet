{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Flutter Web (Edge)",
			"type": "shell",
			"command": "flutter",
			"args": [
				"run",
				"-d",
				"edge",
				"--web-renderer",
				"html"
			],
			"isBackground": false,
			"problemMatcher": [
				"$dart-flutter"
			],
			"group": "build"
		}
	]
}